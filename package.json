{
  "name": "bwv-nhattp-research-nitro-drizzle-radash",
  "packageManager": "yarn@4.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn dev:api & yarn dev:front",
    "dev:api": "yarn workspace @intern/api dev",
    "dev:front": "yarn workspace @intern/front dev",
    "lint": "eslint \"{packages,apps}/*/src/**/*.{ts,vue,tsx}\" \"apps/front/**/*.{ts,vue,tsx}\" --ignore-pattern '**/.*'",
    "lint:fix": "eslint \"{packages,apps}/*/src/**/*.{ts,vue,tsx}\" \"apps/front/**/*.{ts,vue,tsx}\"  --ignore-pattern '**/.*' --fix",
    "prettier": "prettier --check \"{packages,apps}/*/src/**/*.{ts,vue,tsx}\"  \"apps/front/**/*.{ts,vue,tsx}\"",
    "format": "prettier --write \"{packages,apps}/*/src/**/*.{ts,vue,tsx}\"  \"apps/front/**/*.{ts,vue,tsx}\"",
    "build:front": "yarn workspace @intern/front build",
    "build:api": "yarn workspace @intern/api build",
    "db:gen": "yarn workspace @intern/domain db:gen",
    "db:migrate": "yarn workspace @intern/domain db:migrate"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "http-status-codes": "^2.3.0",
    "nitropack": "^2.13.4",
    "pg": "^8.16.3",
    "radash": "^12.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "5.7.3",
    "vue-eslint-parser": "^10.1.3"
  }
}
